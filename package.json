{
  "name": "@theyahia/mindbox-mcp",
  "version": "1.0.0",
  "description": "MCP server for Mindbox CDP API — customer profiles, orders, segments, product lists, and custom operations. 6 tools. Stdio + Streamable HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mindbox-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "smithery.yaml"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "modelcontextprotocol",
    "claude",
    "ai",
    "llm",
    "anthropic",
    "cursor",
    "ai-tools",
    "ai-agent",
    "russian-api",
    "mindbox",
    "cdp",
    "crm",
    "customer",
    "marketing-automation",
    "streamable-http"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/mindbox-mcp.git"
  },
  "homepage": "https://github.com/theYahia/mindbox-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)",
  "mcpName": "io.github.theYahia/mindbox-mcp"
}
